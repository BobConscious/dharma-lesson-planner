# ----------------------------------------------------------------------------
# Dharma Lesson Planner — environment
# Copy this file to `.env` and fill in your own keys. Nothing here is exposed to
# the browser; all live API calls happen in the Node server (server/index.ts).
# ----------------------------------------------------------------------------

# Your organization id from the Dharma AI console (e.g. org_12345)
DHARMA_ORG_ID=org_12345

# A scoped developer token. Needs the rag:search scope (and rag:rerank if you
# leave reranking on). Keep it secret — it starts with dharma_org_.
DHARMA_DEV_TOKEN=dharma_org_xxxxxxxxxxxxxxxxxxxxx

# Gemini API key (Google AI Studio). Used by the Vercel AI SDK.
GOOGLE_GENERATIVE_AI_API_KEY=your_gemini_api_key

# --- optional -------------------------------------------------------------
# Port for the local server (default 3000)
# PORT=3000

# Override the Dharma API base. Defaults to the production endpoint.
# For local platform development use: http://localhost:3000/api
# DHARMA_API_BASE_URL=https://dharma-ai.io/api

# Set to "false" to skip the rerank pass and save 10 credits per plan.
# DHARMA_USE_RERANK=true

# Override the Gemini model. Defaults to gemini-2.5-flash.
# GEMINI_MODEL=gemini-2.5-flash
